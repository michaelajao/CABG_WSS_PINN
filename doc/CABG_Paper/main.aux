\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \added {Full-patient WSS comparison for the healthy case H1 under the \emph  {Newtonian} surrogate, shown in two orthogonal projections. Each panel reports CFD ground truth (left), PINN prediction (middle), and absolute error (right). Absolute errors remain predominantly below 0.6~Pa across the geometry, with slightly elevated errors (0.8--1.2~Pa) at bifurcations where wall-normal velocity gradients are steepest.}}}{30}{figure.caption.21}\protected@file@percent }
\newlabel{fig:pinn_wss_h1}{{6}{30}{\addp {Full-patient WSS comparison for the healthy case H1 under the \emph {Newtonian} surrogate, shown in two orthogonal projections. Each panel reports CFD ground truth (left), PINN prediction (middle), and absolute error (right). Absolute errors remain predominantly below 0.6~Pa across the geometry, with slightly elevated errors (0.8--1.2~Pa) at bifurcations where wall-normal velocity gradients are steepest.}}{figure.caption.21}{}}
