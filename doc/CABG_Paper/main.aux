\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \added {Full-patient WSS comparison under the \emph  {Newtonian} surrogate for the SVG case BG2 (panels a, b) and the diseased case D3 (panels c, d), shown in two orthogonal projections. Each panel reports CFD ground truth (left), PINN prediction (middle), and absolute error (right). The PINN reproduces the multi-anastomosis bypass-graft pattern (G1, G2, G3) of BG2 and the high-stress focal regions at bifurcations and stenoses of D3; residual error concentrates at anastomosis sites and high-curvature regions where wall-normal gradients are steepest.}}}{31}{figure.caption.22}\protected@file@percent }
\newlabel{fig:pinn_wss_svg_diseased}{{7}{31}{\addp {Full-patient WSS comparison under the \emph {Newtonian} surrogate for the SVG case BG2 (panels a, b) and the diseased case D3 (panels c, d), shown in two orthogonal projections. Each panel reports CFD ground truth (left), PINN prediction (middle), and absolute error (right). The PINN reproduces the multi-anastomosis bypass-graft pattern (G1, G2, G3) of BG2 and the high-stress focal regions at bifurcations and stenoses of D3; residual error concentrates at anastomosis sites and high-curvature regions where wall-normal gradients are steepest.}}{figure.caption.22}{}}
