\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces FourierPINN surrogate for WSS prediction. Input coordinates $(x,y,z)$ pass through the Fourier feature map, a trunk of 6 residual blocks (\added {detailed in Figure~\ref {fig:pinn_resblock}}), and five output heads $u,v,w,p,\tau _w$. The five loss components $\mathcal  {L}_{\text  {wss}}$, $\mathcal  {L}_{\text  {vel}}$, $\mathcal  {L}_{\text  {NS}}$, $\mathcal  {L}_{\text  {cont}}$, $\mathcal  {L}_\tau $ are aggregated into the total loss $\mathcal  {L}$; the dashed arrow labelled \emph  {autodiff} marks where the spatial derivatives feeding the physics losses are obtained by automatic differentiation through the trunk.}}{11}{figure.caption.3}\protected@file@percent }
\newlabel{fig:pinn_arch}{{2}{11}{FourierPINN surrogate for WSS prediction. Input coordinates $(x,y,z)$ pass through the Fourier feature map, a trunk of 6 residual blocks (\addp {detailed in Figure~\ref {fig:pinn_resblock}}), and five output heads $u,v,w,p,\tau _w$. The five loss components $\mathcal {L}_{\text {wss}}$, $\mathcal {L}_{\text {vel}}$, $\mathcal {L}_{\text {NS}}$, $\mathcal {L}_{\text {cont}}$, $\mathcal {L}_\tau $ are aggregated into the total loss $\mathcal {L}$; the dashed arrow labelled \emph {autodiff} marks where the spatial derivatives feeding the physics losses are obtained by automatic differentiation through the trunk}{figure.caption.3}{}}
