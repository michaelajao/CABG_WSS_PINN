\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \added {Full-patient WSS comparison under the \emph  {Carreau--Yasuda} surrogate for the SVG case BG2 (panels a, b) and the diseased case D3 (panels c, d), shown in the same projections as Figure~\ref {fig:pinn_wss_svg_diseased} for direct rheology comparison. Each panel reports Carreau--Yasuda CFD ground truth (left), PINN prediction (middle), and absolute error (right). The non-Newtonian closure does not introduce qualitatively new error patterns: residuals concentrate at the same anastomosis and high-curvature locations as in the Newtonian case, consistent with the small mean NRMSE gap reported in Tables~\ref {tab:pinn_holdout} and~\ref {tab:pinn_holdout_cy}.}}}{33}{figure.caption.24}\protected@file@percent }
\newlabel{fig:pinn_wss_svg_diseased_cy}{{9}{33}{\addp {Full-patient WSS comparison under the \emph {Carreau--Yasuda} surrogate for the SVG case BG2 (panels a, b) and the diseased case D3 (panels c, d), shown in the same projections as Figure~\ref {fig:pinn_wss_svg_diseased} for direct rheology comparison. Each panel reports Carreau--Yasuda CFD ground truth (left), PINN prediction (middle), and absolute error (right). The non-Newtonian closure does not introduce qualitatively new error patterns: residuals concentrate at the same anastomosis and high-curvature locations as in the Newtonian case, consistent with the small mean NRMSE gap reported in Tables~\ref {tab:pinn_holdout} and~\ref {tab:pinn_holdout_cy}.}}{figure.caption.24}{}}
